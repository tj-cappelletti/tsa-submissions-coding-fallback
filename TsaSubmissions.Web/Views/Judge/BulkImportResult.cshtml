@model TsaSubmissions.Web.ViewModels.BulkImportResultViewModel
@{
    ViewData["Title"] = "Import Results";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-10">
        @if (Model.SuccessCount > 0)
        {
            <div class="alert alert-success" role="alert">
                <h5 class="alert-heading">✓ Successfully imported @Model.SuccessCount user(s)</h5>
            </div>
        }

        @if (Model.FailureCount > 0)
        {
            <div class="alert alert-warning" role="alert">
                <h5 class="alert-heading">⚠ @Model.FailureCount user(s) failed to import</h5>
                @if (Model.Errors.Any())
                {
                    <hr>
                    <h6>Errors:</h6>
                    <ul class="mb-0">
                        @foreach (var error in Model.Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                }
            </div>
        }

        <div class="mt-4">
            <a asp-action="BulkImportUsers" class="btn btn-primary">Import More Users</a>
            <a asp-action="UserList" class="btn btn-secondary">View User List</a>
        </div>
    </div>
</div>
